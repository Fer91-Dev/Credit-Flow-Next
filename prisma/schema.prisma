generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model clientes {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  nombre       String
  documento    String?
  email        String?
  telefono     String?
  direccion    String?
  estado       String   @default("activo")
  tipo_credito String   @default("personal")
  monto_total  Float    @default(0)
  user_id      String   @db.Uuid

  // Datos personales ampliados
  fecha_nacimiento DateTime? @db.Date
  cuit_cuil        String?
  estado_civil     String?
  nacionalidad     String?

  // Situación laboral
  situacion_laboral        String? // relacion_dependencia | autonomo | monotributista | jubilado | desempleado | otro
  ocupacion                String?
  empleador                String?
  antiguedad_laboral_meses Int?

  // Ingresos / capacidad de pago
  ingreso_mensual Float?
  otros_ingresos  Float?

  // Contacto laboral
  telefono_laboral  String?
  direccion_laboral String?

  creditos    creditos[]
  solicitudes solicitudes[]
}

model creditos {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  cliente_id      String    @db.Uuid
  solicitud_id    String?   @db.Uuid
  tipo_credito    String
  monto_original  Float
  saldo_pendiente Float
  tasa            Float     @default(0)
  plazo_meses     Int       @default(12) // número de cuotas (el período lo da `frecuencia`)
  frecuencia      String    @default("mensual") // clave de frecuencia (built-in o personalizada)
  frecuencia_def  Json?     // snapshot de la definición de frecuencia vigente al otorgar (congela días/períodos)
  fecha_inicio    DateTime  @default(now()) @db.Date
  proximo_pago    DateTime? @db.Date
  dias_mora       Int       @default(0)
  estado          String    @default("activo")
  cargos          Json?     // snapshot de CargosConfig vigente al otorgar (congela los cargos del crédito)
  user_id         String    @db.Uuid

  cliente   clientes     @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  solicitud solicitudes? @relation(fields: [solicitud_id], references: [id], onDelete: SetNull)
  pagos     pagos[]
  acciones  acciones_cobranza[]
  cuotas    cuotas[]
}

/// Plan de cuotas PERSISTIDO de un crédito (Fase 6A). Tabla aditiva, multi-tenant.
/// Se genera al otorgar desde construirPlanAmortizacion (congela el cronograma).
/// En 6A las columnas `estado`/`pagado` se DERIVAN en lectura desde los pagos del
/// crédito (capa paralela); quedan persistidas para la imputación cuota-dirigida (6B).
model cuotas {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  user_id           String   @db.Uuid
  credito_id        String   @db.Uuid
  nro               Int      // número de cuota (1..n)
  fecha_vencimiento DateTime @db.Date
  // Plan congelado (desde construirPlanAmortizacion al generar)
  saldo_inicial     Float    // capital pendiente al inicio del período
  capital           Float    // abono a capital planificado
  interes           Float    // interés planificado del período
  iva               Float    @default(0)
  seguro            Float    @default(0)
  gastos            Float    @default(0)
  cuota_total       Float    // cuota total planificada (con redondeo)
  // Estado — en 6A se DERIVA en lectura; estas columnas quedan para 6B
  estado            String   @default("pendiente") // pendiente | parcial | pagada | vencida
  pagado            Float    @default(0)

  credito creditos @relation(fields: [credito_id], references: [id], onDelete: Cascade)

  @@unique([credito_id, nro])
  @@index([user_id, credito_id])
  @@index([user_id, fecha_vencimiento])
}

model pagos {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  credito_id       String   @db.Uuid
  monto            Float
  fecha            DateTime @default(now()) @db.Date
  metodo           String   @default("efectivo")
  notas            String?
  user_id          String   @db.Uuid
  aplicado_mora    Float    @default(0)
  aplicado_interes Float    @default(0)
  aplicado_cargos  Float    @default(0)
  aplicado_capital Float    @default(0)
  excedente        Float    @default(0)

  credito creditos @relation(fields: [credito_id], references: [id], onDelete: Cascade)
}

model solicitudes {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  cliente_id   String    @db.Uuid
  tipo_credito String
  monto        Float
  plazo_meses  Int       @default(12)
  score        Int       @default(0)
  estado       String    @default("pendiente")
  notas        String?
  decided_at   DateTime? @db.Timestamptz(6)
  user_id      String    @db.Uuid

  cliente  clientes   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  creditos creditos[]
}

model profiles {
  id         String   @id @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  full_name  String?
}

/// Gestiones de cobranza sobre un crédito en mora (llamadas, promesas de pago, etc.).
/// Tabla aditiva, multi-tenant. Permite historial + recordatorios (proximo_contacto).
model acciones_cobranza {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  user_id          String    @db.Uuid
  credito_id       String    @db.Uuid
  tipo             String    // llamada | whatsapp | email | visita | otro
  resultado        String    // contactado | no_contesta | promesa_pago | renegociacion | ilocalizable | otro
  nota             String?
  promesa_monto    Float?
  promesa_fecha    DateTime? @db.Date
  proximo_contacto DateTime? @db.Date

  credito creditos @relation(fields: [credito_id], references: [id], onDelete: Cascade)

  @@index([user_id, credito_id])
  @@index([user_id, proximo_contacto])
}

/// Traza de auditoría: registra eventos de negocio por tenant (user_id).
/// Tabla aditiva, solo escritura desde el backend y lectura en la vista.
model auditoria {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  user_id     String   @db.Uuid
  entidad     String   // clientes | creditos | pagos | configuracion
  entidad_id  String?  @db.Uuid
  accion      String   // crear | actualizar | eliminar | cancelar | registrar_pago | actualizar_config
  descripcion String
  meta        Json?

  @@index([user_id, created_at])
}

/// Configuración del motor financiero por financiera (tenant = user_id).
model configuraciones {
  user_id              String   @id @db.Uuid
  convencion_tasa      String   @default("nominal_anual")
  sistema_amortizacion String   @default("frances")
  mora_activa          Boolean  @default(true)
  tasa_mora_diaria     Float    @default(0.01)
  base_mora            String   @default("cuota")
  orden_imputacion     String   @default("mora,interes,capital")
  imputar_cargos       String   @default("integrado")
  moneda               String   @default("ARS")
  locale               String   @default("es-AR")
  simulador            Json?    // SimuladorConfig (parámetros del motor de cuota por tenant)
  updated_at           DateTime @updatedAt @db.Timestamptz(6)
}
