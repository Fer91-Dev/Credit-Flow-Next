generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO ORG (multi-usuario por financiera)
//
// `tenants`  = la financiera (organización). Es el TENANT real del sistema.
// `profiles` = la persona que loguea (= auth.users.id), pertenece a un tenant y
//              tiene un ROL. Fuente de verdad del control de acceso.
//
// Toda tabla operativa se aísla por `tenant_id` (antes `user_id`, resignificado).
// El aislamiento se aplica en la capa app (`withTenant`) + RLS de Postgres.
// ─────────────────────────────────────────────────────────────────────────────

/// Roles de acceso dentro de una financiera (tenant). Deny-by-default: un profile
/// sin rol (role = null) o inactivo NO tiene acceso a nada.
enum Role {
  admin    // Dueño/gerente: acceso total (Reportes, Caja, Configuración, Auditoría)
  vendedor // Comercial: ABM clientes + alta/simulación de créditos
  cobrador // Mora y cobro: Pagos + Cobranza; ve clientes/créditos, no crea créditos
}

/// Financiera / organización. Es el "tenant" del sistema multi-tenant.
/// Toda la data operativa pertenece a un tenant; las personas (profiles) también.
model tenants {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  nombre     String
  activo     Boolean  @default(true)

  profiles profiles[]
}

/// Identidad de un usuario autenticado (= auth.users.id) dentro de una financiera.
/// Fuente de verdad del ROL. La FK profiles.id → auth.users(id) y el trigger de
/// alta (handle_new_user) se manejan a nivel SQL (Supabase no es modelable por Prisma).
///
/// Deny-by-default: un profile recién creado nace con tenant_id = null, role = null
/// y activo = false → sin acceso a nada hasta que un admin lo asigne y active.
model profiles {
  id          String   @id @db.Uuid // = auth.users.id (Supabase Auth)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  full_name   String?
  email       String?
  tenant_id   String?  @db.Uuid // nullable: deny-by-default hasta asignar
  role        Role? // nullable: sin rol = acceso denegado
  activo      Boolean  @default(false) // inerte hasta que el admin lo active
  vendedor_id String?  @db.Uuid // vínculo opcional al registro comercial (si role = vendedor)

  tenant   tenants?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  vendedor vendedores? @relation(fields: [vendedor_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
}

model clientes {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  nombre       String   // nombre(s) de pila
  apellido     String?  // apellido(s) — separado de nombre (modelo normalizado)
  documento    String?
  email        String?
  telefono     String?
  direccion    String?
  estado       String   @default("activo")
  tipo_credito String   @default("personal")
  monto_total  Float    @default(0)
  zona         String?  // zona/barrio para segmentación geográfica (Fase Home)
  tenant_id    String   @db.Uuid

  // Datos personales ampliados
  fecha_nacimiento DateTime? @db.Date
  cuit_cuil        String?
  estado_civil     String?
  nacionalidad     String?

  // Situación laboral
  situacion_laboral        String? // relacion_dependencia | autonomo | monotributista | jubilado | desempleado | otro
  ocupacion                String?
  empleador                String?
  antiguedad_laboral_meses Int?

  // Ingresos / capacidad de pago
  ingreso_mensual Float?
  otros_ingresos  Float?

  // Contacto laboral
  telefono_laboral  String?
  direccion_laboral String?

  creditos    creditos[]
  solicitudes solicitudes[]

  @@index([tenant_id])
}

model creditos {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  numero           Int? // identificador legible secuencial por tenant (se muestra como CRD-000123)
  motivo_anulacion String? // motivo registrado al anular el crédito
  cliente_id       String    @db.Uuid
  solicitud_id     String?   @db.Uuid
  tipo_credito     String
  monto_original   Float
  saldo_pendiente  Float
  tasa             Float     @default(0)
  plazo_meses      Int       @default(12) // número de cuotas (el período lo da `frecuencia`)
  frecuencia       String    @default("mensual") // clave de frecuencia (built-in o personalizada)
  frecuencia_def   Json? // snapshot de la definición de frecuencia vigente al otorgar (congela días/períodos)
  fecha_inicio     DateTime  @default(now()) @db.Date
  proximo_pago     DateTime? @db.Date
  dias_mora        Int       @default(0)
  estado           String    @default("activo")
  cargos           Json? // snapshot de CargosConfig vigente al otorgar (congela los cargos del crédito)
  cronograma       Json? // snapshot del cronograma (corte/día venc/gracia/feriados) vigente al otorgar
  tenant_id        String    @db.Uuid

  vendedor_id String? @db.Uuid // vendedor que otorgó el crédito (Fase 5, opcional)

  cliente           clientes           @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  solicitud         solicitudes?       @relation(fields: [solicitud_id], references: [id], onDelete: SetNull)
  vendedor          vendedores?        @relation(fields: [vendedor_id], references: [id], onDelete: SetNull)
  pagos             pagos[]
  acciones          acciones_cobranza[]
  cuotas            cuotas[]
  movimientos       movimientos_caja[]
  objetivos_campana campana_objetivo[]

  @@unique([tenant_id, numero])
  @@index([tenant_id, vendedor_id])
}

/// Personal de ventas/cobranza (Fase 5). Tabla aditiva, multi-tenant.
/// Registro COMERCIAL del vendedor (comisión, meta). La identidad de login y el rol
/// real viven en `profiles` (profiles.vendedor_id → vendedores.id).
/// `rol` (texto) queda por retrocompatibilidad; se deprecará en una fase posterior.
model vendedores {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  tenant_id    String   @db.Uuid
  nombre       String
  email        String?
  telefono     String?
  rol          String   @default("vendedor") // DEPRECADO (ver profiles.role): vendedor | supervisor | cobrador | admin
  comision_pct Float    @default(0) // % de comisión sobre el monto otorgado
  meta_venta   Float    @default(0) // meta de venta del período (0 = sin meta)
  activo       Boolean  @default(true)

  // Datos laborales y parametrización del empleado (Fase 1)
  documento         String?   // DNI / CUIL
  fecha_ingreso     DateTime? @db.Date
  direccion         String?
  zona              String?   // zona o sucursal asignada
  notas             String?   // notas internas
  limite_aprobacion Float?    // monto máximo que puede otorgar sin autorización (null = sin límite)
  comision_config   Json?     // comisión avanzada (Fase 2): { base_pct, por_tipo, tramos, bonus_meta }. null = % plano

  creditos creditos[]
  profiles profiles[] // back-relation del vínculo profiles.vendedor_id
  metas    metas_vendedor[]

  @@index([tenant_id])
}

/// Metas/objetivos de un vendedor por período (Fase 3). Aditiva, multi-tenant.
/// Permite metas de monto, cantidad de créditos y cobranza, con histórico. La
/// meta "vigente" sincroniza vendedores.meta_venta para los KPIs existentes.
model metas_vendedor {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  tenant_id     String   @db.Uuid
  vendedor_id   String   @db.Uuid
  periodo       String   // etiqueta del período, ej. "2026-06" o "2026-T2"
  fecha_desde   DateTime @db.Date
  fecha_hasta   DateTime @db.Date
  meta_monto    Float    @default(0) // objetivo de monto otorgado
  meta_cantidad Int      @default(0) // objetivo de cantidad de créditos
  meta_cobranza Float    @default(0) // objetivo de monto cobrado/recuperado
  estado        String   @default("vigente") // vigente | cerrada

  vendedor vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([vendedor_id])
}

/// Campaña de recuperación de cobranza (Fase 7A). Tabla aditiva, multi-tenant.
/// Agrupa créditos en mora para aplicar acciones masivas (WhatsApp/Email/SMS) y
/// una promoción opcional (quita de interés de mora). La APLICACIÓN automática de
/// la quita al cobrar es Fase 7B (no toca el motor de pagos todavía).
model campanas_cobranza {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  tenant_id        String    @db.Uuid
  nombre           String
  descripcion      String?
  canal            String    @default("whatsapp") // whatsapp | email | sms
  estado           String    @default("borrador") // borrador | activa | finalizada
  promo_tipo       String    @default("ninguna") // ninguna | quita_interes
  promo_valor      Float     @default(0) // % de descuento sobre el interés de mora
  promo_vence      DateTime? @db.Date // plazo límite para acogerse a la promo
  mensaje_template String? // plantilla del mensaje (con [Nombre], [Monto], etc.)

  objetivos campana_objetivo[]

  @@index([tenant_id, created_at])
}

/// Vínculo campaña ↔ crédito en mora (tabla intermedia, Fase 7A). Multi-tenant.
/// Congela un snapshot de la situación de mora al incorporar el crédito a la campaña
/// y la oferta de recuperación calculada. `monto_recuperado` se actualiza con los
/// pagos imputados a ese crédito mientras la campaña esté activa.
model campana_objetivo {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  tenant_id        String   @db.Uuid
  campana_id       String   @db.Uuid
  credito_id       String   @db.Uuid
  // Snapshot de la mora al incorporar a la campaña
  saldo            Float    @default(0)
  dias_mora        Int      @default(0)
  interes_mora     Float    @default(0)
  // Oferta de recuperación calculada (calculateRecoveryOffer)
  oferta_monto     Float    @default(0) // monto a cancelar con descuento aplicado
  oferta_descuento Float    @default(0) // $ de descuento (ahorro) ofrecido
  // Seguimiento
  promesa_generada Boolean  @default(false)
  monto_recuperado Float    @default(0)

  campana campanas_cobranza @relation(fields: [campana_id], references: [id], onDelete: Cascade)
  credito creditos          @relation(fields: [credito_id], references: [id], onDelete: Cascade)

  @@unique([campana_id, credito_id])
  @@index([tenant_id, campana_id])
  @@index([tenant_id, credito_id])
}

/// Libro de movimientos de efectivo (Caja) por tenant. Tabla aditiva, multi-tenant.
/// monto con SIGNO: ingreso > 0, egreso < 0. El saldo de caja = suma de monto.
model movimientos_caja {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  tenant_id   String   @db.Uuid
  fecha       DateTime @default(now()) @db.Date
  tipo        String // desembolso | cobro | devolucion | reversa_desembolso | ajuste | transferencia
  monto       Float // con signo: ingreso > 0, egreso < 0
  metodo      String?
  cuenta      String   @default("efectivo") // efectivo | banco | dolares
  descripcion String
  credito_id  String?  @db.Uuid
  pago_id     String?  @db.Uuid

  credito creditos? @relation(fields: [credito_id], references: [id], onDelete: Cascade)
  pago    pagos?    @relation(fields: [pago_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, fecha])
  @@index([tenant_id, credito_id])
  @@index([tenant_id, cuenta])
}

/// Plan de cuotas PERSISTIDO de un crédito (Fase 6A). Tabla aditiva, multi-tenant.
/// Se genera al otorgar desde construirPlanAmortizacion (congela el cronograma).
/// En 6A las columnas `estado`/`pagado` se DERIVAN en lectura desde los pagos del
/// crédito (capa paralela); quedan persistidas para la imputación cuota-dirigida (6B).
model cuotas {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  tenant_id         String   @db.Uuid
  credito_id        String   @db.Uuid
  nro               Int // número de cuota (1..n)
  fecha_vencimiento DateTime @db.Date
  // Plan congelado (desde construirPlanAmortizacion al generar)
  saldo_inicial     Float // capital pendiente al inicio del período
  capital           Float // abono a capital planificado
  interes           Float // interés planificado del período
  iva               Float    @default(0)
  seguro            Float    @default(0)
  gastos            Float    @default(0)
  cuota_total       Float // cuota total planificada (con redondeo)
  // Estado autoritativo (escrito por el motor de pagos en 6B; en 6A se derivaba).
  estado            String   @default("pendiente") // pendiente | parcial | pagada | vencida
  pagado            Float    @default(0) // total aplicado a la cuota (capital+interes+mora+cargos)
  // Desglose de lo aplicado por componente (Fase 6B)
  pagado_capital    Float    @default(0)
  pagado_interes    Float    @default(0)
  pagado_mora       Float    @default(0)
  pagado_cargos     Float    @default(0)

  credito      creditos     @relation(fields: [credito_id], references: [id], onDelete: Cascade)
  aplicaciones pago_cuota[]

  @@unique([credito_id, nro])
  @@index([tenant_id, credito_id])
  @@index([tenant_id, fecha_vencimiento])
}

/// Aplicación de un pago a una cuota concreta (libro mayor pago↔cuota, Fase 6B).
/// Tabla aditiva, multi-tenant. Permite saber exactamente qué pago canceló qué cuota.
model pago_cuota {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  tenant_id        String   @db.Uuid
  pago_id          String   @db.Uuid
  cuota_id         String   @db.Uuid
  aplicado_capital Float    @default(0)
  aplicado_interes Float    @default(0)
  aplicado_mora    Float    @default(0)
  aplicado_cargos  Float    @default(0)

  pago  pagos  @relation(fields: [pago_id], references: [id], onDelete: Cascade)
  cuota cuotas @relation(fields: [cuota_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, pago_id])
  @@index([tenant_id, cuota_id])
}

model pagos {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  credito_id       String   @db.Uuid
  monto            Float
  fecha            DateTime @default(now()) @db.Date
  metodo           String   @default("efectivo")
  notas            String?
  tenant_id        String   @db.Uuid
  aplicado_mora    Float    @default(0)
  aplicado_interes Float    @default(0)
  aplicado_cargos  Float    @default(0)
  aplicado_capital Float    @default(0)
  excedente        Float    @default(0)

  credito      creditos           @relation(fields: [credito_id], references: [id], onDelete: Cascade)
  aplicaciones pago_cuota[]
  movimientos  movimientos_caja[]

  @@index([tenant_id])
}

model solicitudes {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  cliente_id   String    @db.Uuid
  tipo_credito String
  monto        Float
  plazo_meses  Int       @default(12)
  score        Int       @default(0)
  estado       String    @default("pendiente")
  notas        String?
  decided_at   DateTime? @db.Timestamptz(6)
  tenant_id    String    @db.Uuid

  cliente  clientes   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  creditos creditos[]

  @@index([tenant_id])
}

/// Gestiones de cobranza sobre un crédito en mora (llamadas, promesas de pago, etc.).
/// Tabla aditiva, multi-tenant. Permite historial + recordatorios (proximo_contacto).
model acciones_cobranza {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  tenant_id        String    @db.Uuid
  credito_id       String    @db.Uuid
  tipo             String // llamada | whatsapp | email | visita | otro
  resultado        String // contactado | no_contesta | promesa_pago | renegociacion | ilocalizable | otro
  nota             String?
  promesa_monto    Float?
  promesa_fecha    DateTime? @db.Date
  proximo_contacto DateTime? @db.Date
  automatico       Boolean   @default(false) // true = enviado por el motor automático (cron)
  promesa_estado   String? // pendiente | cumplida | incumplida (solo cuando resultado = promesa_pago)

  credito creditos @relation(fields: [credito_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, credito_id])
  @@index([tenant_id, proximo_contacto])
  @@index([tenant_id, promesa_estado])
}

/// Traza de auditoría: registra eventos de negocio por tenant (tenant_id).
/// Tabla aditiva, solo escritura desde el backend y lectura en la vista.
model auditoria {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  tenant_id   String   @db.Uuid
  entidad     String // clientes | creditos | pagos | configuracion
  entidad_id  String?  @db.Uuid
  accion      String // crear | actualizar | eliminar | cancelar | registrar_pago | actualizar_config
  descripcion String
  meta        Json?

  @@index([tenant_id, created_at])
}

/// Proveedores / acreedores (Fase 6). Tabla aditiva, multi-tenant.
/// Cubren tanto gastos operativos como fondeo de la financiera. Cada proveedor
/// tiene una cuenta corriente (movimientos_proveedor) con su saldo.
model proveedores {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  tenant_id  String   @db.Uuid
  nombre     String
  cuit       String?
  email      String?
  telefono   String?
  direccion  String?
  rubro      String? // rubro/categoría (servicios, fondeo, insumos, etc.)
  notas      String?
  activo     Boolean  @default(true)

  movimientos movimientos_proveedor[]

  @@index([tenant_id])
}

/// Cuenta corriente de un proveedor (Fase 6). Tabla aditiva, multi-tenant.
/// monto con SIGNO: cargo > 0 (aumenta lo que le debemos), pago < 0 (lo cancela).
/// El saldo de la cuenta = suma de los montos (positivo = deuda pendiente con el proveedor).
model movimientos_proveedor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  tenant_id    String   @db.Uuid
  proveedor_id String   @db.Uuid
  fecha        DateTime @default(now()) @db.Date
  tipo         String // cargo (factura/gasto/fondeo recibido) | pago (cancelación)
  monto        Float // con signo: cargo > 0, pago < 0
  concepto     String
  comprobante  String? // N° de factura/comprobante
  metodo       String? // medio de pago (efectivo, transferencia, etc.)

  proveedor proveedores @relation(fields: [proveedor_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, proveedor_id])
  @@index([tenant_id, fecha])
}

/// Configuración del motor financiero por financiera (tenant = tenant_id).
model configuraciones {
  tenant_id            String   @id @db.Uuid
  convencion_tasa      String   @default("nominal_anual")
  sistema_amortizacion String   @default("frances")
  mora_activa          Boolean  @default(true)
  tasa_mora_diaria     Float    @default(0.01)
  base_mora            String   @default("cuota")
  orden_imputacion     String   @default("mora,interes,capital")
  imputar_cargos       String   @default("integrado")
  moneda               String   @default("ARS")
  locale               String   @default("es-AR")
  simulador            Json? // SimuladorConfig (parámetros del motor de cuota por tenant)
  whatsapp_config      Json? // { enabled, token, phone_number_id, business_account_id, templates: { recordatorio, vencimiento, mora_temprana, mora_media, mora_critica } }
  sms_config           Json? // { enabled, api_key, provider }
  email_config         Json? // { enabled, host, port, user, pass } o { enabled, api_key, provider }
  gamificacion_config  Json? // { habilitado, periodo, pesos:{monto,cantidad,cobranza,calidad}, umbrales:{oro,plata,bronce} }
  updated_at           DateTime @updatedAt @db.Timestamptz(6)
}
